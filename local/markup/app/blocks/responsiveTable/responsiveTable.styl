table.responsiveTable {
	-webkit-box-sizing: border-box;
	-moz-box-sizing: border-box;
	box-sizing: border-box;
	clear:both;
	border:none;
	width:100%;
	height:100%;
	text-align:center;
}

table.responsiveTable th, table.responsiveTable td {
	-webkit-box-sizing: border-box;
	-moz-box-sizing: border-box;
	box-sizing: border-box;
}
