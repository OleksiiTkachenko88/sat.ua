.uk-form-select
	display inline-block
	vertical-align middle
	position relative
	overflow hidden
	padding-left 0
	padding-right 0

	&.uk-button
	&.uk-button:hover
	&.uk-button:focus
		padding-left 0
		padding-right 0
		height 35px
		background-color #d4e0ec
		border-color #d4e0ec

	&.uk-button > span
		font-family $base-font-family-light
		font-weight normal
		font-size 22px
		line-height normal
		display inline-block
		padding 7px 50px 7px 14px
		height 35px
		text-truncate()
		position relative

		&:before
			content ''
			display block
			position absolute
			top 50%
			margin-top -6px
			right 12px
			sprite($icon_chevron_down_grey)

	select
		position absolute
		top 0
		z-index 1
		width 100%
		height 100%
		opacity 0
		cursor pointer
		left 0
		-webkit-appearance none
		padding-right 35px !important
