.uniform-bg-3
.uniform-bg-2
.uniform-bg-1
	padding .15em 0
	position relative
	background #2766a0
	color #fff

	.main-slide__extra-title &
		background-color #2766a0
		color #ffffff
		padding-top .075em
		padding-bottom .075em

	.main-slide__title &
		background-color #ffffff
		color #2766a0

.uniform-bg-1
	left -.6em

	.main-slide__extra-title &
	.main-slide__title &
		left -.3em

	.main-slide__extra-title &
		left -.15em


.uniform-bg-2
	left .6em

	.main-slide__extra-title &
		left .3em

.uniform-bg-3
	left -.3em

	.main-slide__extra-title &
		left -.15em


.help-block
	display block
	typo-hint()

.tooltip-map
	background-color #ffd64a
	color #404041
	display inline-block
	width 280px
	padding 12px 15px 15px 30px
	border-radius 5px

	&__title
		font-size 24px
		line-height 30px
		color inherit

	&__text
	&__text-alt
		font-size 18px
		line-height 23px

	&__text
		color inherit
		overflow hidden
		zoom 1

	&__text-alt
		color #8b7528

		.title-width-1
			display inline-block
			vertical-align baseline
			min-width 85px

	&__hr
		display block
		border-top 1px solid #8b7528
		margin-top 7px
		margin-bottom 7px

	&__arrow
		right 100%
		top 15px
		border solid transparent
		content ''
		height 0
		width 0
		position absolute
		pointer-events none
		border-color rgba(255, 214, 74, 0)
		border-right-color #ffd64a
		border-width 12px

.cabinet-link
	font-family $base-font-family
	font-weight normal
	font-size 24px
	line-height 2.16
	text-transform uppercase
	padding 30px
	text-decoration none
	display block
	margin-top 10px
	margin-bottom 10px
	text-align center
	background-color #d0d2d3
	color #2766a0

	+below($breakpoint-lg - 1px)
		font-size 16px
		margin-left -15px
		margin-right -15px
		padding 15px 20px

	a&:hover
		background-color #ffd64a
		color #2766a0
		text-decoration none

	.icon
		margin-left 15px
		margin-right 25px
		vertical-align middle

	.icon--entry-accent-59-52:before
	.icon--entry-blue-59-52:before
		width 2.458333em
		height 2.16667em
		background-position 0 0
		background-size cover

	.icon--entry-accent-59-52:before
		background-image url('data:image/png;base64,')

	.icon--entry-blue-59-52:before
		background-image url('data:image/png;base64,')

	& strong
	& a
		color inherit
		text-decoration underline
		font-family $base-font-family-heavy
		transition $transition-default

	& a:hover
	& a:focus
		color #ffe17f

	&--alt
		background-color #1e3e6c
		color #ffd54b

		a&:hover
			background-color #ffd64a
			color #2766a0

	.page--index &
		margin-bottom 0

.search-result-hint
	font-family $base-font-family
	font-weight normal
	font-size 14px
	line-height 20px
	text-align center
	color #404040
	margin-bottom 20px