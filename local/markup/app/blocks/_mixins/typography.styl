	line-height 1.222
	color #404041

typo-display-1()
	font-family $base-font-family-medium
	font-size 18px
	font-weight normal
	line-height 1.222
	color #404041

typo-headline()
	font-family $base-font-family-medium
	font-size 14px
	font-weight normal
	line-height 1.4285
