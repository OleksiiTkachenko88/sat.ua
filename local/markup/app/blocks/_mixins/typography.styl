typo-display-4()
	font-family $base-font-family-medium
	font-size 46px
	font-weight normal
	line-height 1.18
	color #404041

typo-display-3()
	font-family $base-font-family-medium
	font-size 37px
	font-weight normal
	line-height 1.222
