							.navbar.navbar--calc.navbar--accent
								.navbar__primary-content
									span.navbar__icon
										span.icon.icon--letter-B
									input.form-control.navbar__form-control(type="text", placeholder="Вкажіть пункт відправлення або поставте крапку на карті")

						.calc-group
							.navbar.navbar--calc.navbar--accent.p-l-0
								.navbar__primary-content
									ul.navbar__nav
										li.active
											a(href='')
