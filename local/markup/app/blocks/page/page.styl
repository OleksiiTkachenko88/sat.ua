@media only screen and (min-width 0px) and (max-width 999px)
	html
		-ms-zoom 70%
		zoom 70%

@media only screen and (min-width 1000px) and (max-width 1399px)
	html
		-ms-zoom 75%
		zoom 75%

@media only screen and (min-width 1400px) and (max-width 1499px)
	html
		-ms-zoom 80%
		zoom 80%

@media only screen and (min-width 1500px) and (max-width 1599px)
	html
		-ms-zoom 90%
		zoom 90%

@media only screen and (min-width 1600px)
	html
		-ms-zoom 100%
		zoom 100%

html
body
	width 100%
	height 100%

.page
	height 100%

	body&
		background-color #fff
		color #414142
		min-width 1240px

		+below($breakpoint-lg - 1px)
			min-width 640px

	div&
		min-height 100%
		display flex
		flex-direction column
		flex-wrap nowrap
		overflow hidden
		height auto

.page__content
	flex 1 0 auto
	flex-grow 1
	flex-shrink 0
	flex-basis auto

.page__navbar-header
	margin-top 40px
	margin-bottom 25px
	position relative
	z-index 2

	+below($breakpoint-lg - 1px)
		margin-top 0
		margin-bottom 10px

.page__navbar-header--search
	animation-duration 0.5s
	animation-timing-function ease-out
	animation-fill-mode both
	transform translateX(100%)
	transform translateX(100% + 100px)
	display none

	.page__navbar-header + &
		margin-top -85px

		+below($breakpoint-lg - 1px)
			margin-top -70px

	&.is-expand
		display block
		transform translateX(0)

+above($breakpoint-lg)
	.page__header.uk-active .page__navbar-header
		margin-top 0

	.page__header.uk-active .page__navbar-header + .page__navbar-header--search
		margin-top -85px

.page__header
	transition $transition-default

	& > .container-fluid
		+below($breakpoint-lg - 1px)
			padding-left 0
			padding-right 0

	.page--layout-main &
		position absolute
		left 0
		top 0
		right 0
		height 100px
		transition left 0.3s ease-in-out

	.uk-offcanvas-page .page--layout-main &
		transition left 0.3s ease-in-out

.page__map
	&-container
		position relative
		height 100vh
		min-height 900px
		background-color #fff

		&.collapse
			height 350px
			min-height 350px
			display block

		&:not(.active)
			.btn--more
				.btn__text
					display inline

				.btn__text + .btn__text
					display none

				.icon:before
					transform translate(-50%, -50%) rotate(0deg)


		&.collapse.in
			height 100vh
			min-height 900px
			display block

		&.active
			.btn--more
				.btn__text
					display none

				.btn__text + .btn__text
					display inline

				.icon:before
					transform translate(-50%, -50%) rotate(180deg)

	&-overlay
		position absolute
		left 0
		right 0
		bottom 0
		top 0

		&--top
			bottom auto

		&--bottom
			top auto
			height 230px

		.table__container--department
			margin-top 125px

			+below($breakpoint-lg - 1px)
				margin-top 70px

.page__row
	clearfix()
	margin-left -15px
	margin-right -15px

.page__col-side
.page__col-section
	float left
	padding-left 15px
	padding-right 15px

.page__col-section
	width 100%

.page__col-side
	width 370px

	+below($breakpoint-lg - 1px)
		max-width 100%
		display block
		position fixed
		right 0
		top 60px
		bottom 0
		left auto
		box-sizing border-box
		transform translateX(100%)
		transform-style preserve-3d
		will-change transform
		transition-property transform
		transition-duration 0.2s
		transition-timing-function cubic-bezier(0.4, 0, 0.2, 1)
		z-index 2001
		background-color #fff

	&.is-visible
		+below($breakpoint-lg - 1px)
			transform translateX(0)

	&-container
		max-height 1600px
		overflow-y auto
		
		+below($breakpoint-lg - 1px)
			position absolute
			left 0
			top 0
			width 100%
			height 100% !important
			max-height 100%
			overflow-y auto

		&.swiper-container
			overflow hidden
			
			+below($breakpoint-lg - 1px)
				overflow hidden
		
.page__col-side-toggle
	position absolute
	right 100%
	top 0
	height 100%
	border-right 5px solid $brand-primary
	z-index 1
	width 25px
	box-sizing border-box

	&-icon
		font-family FontAwesome
		font-size 18px
		width 20px
		height 55px
		line-height 55px
		text-align center
		background-color $brand-primary
		color #fff
		position absolute
		top 50%
		right 0
		margin-top -28px
		display block
		cursor pointer

		&:before
			content '\f104'

			.page__col-side.is-visible &
				content '\f105'

.page__col-section-wrapper
	margin 0 370px 0 0

	+below($breakpoint-lg - 1px)
		margin-right 0

.page__col-side-tint
	position fixed
	left 0
	top 0
	width 100%
	height 100%
	background-color rgba(0, 0, 0, 0.1)
	transition-property transform
	transition-duration .2s
	transition-timing-function $animation-curve-default
	display none
	opacity 0
	z-index 2000

	+below($breakpoint-lg - 1px)
		.page__col-side.is-visible ~ &
			display block
			opacity 1

.page__block
	background-color #fff

	&--tracking
		padding 0

		& > .container-fluid
			padding-left 15px
			padding-right 15px

			+below(1540px)
				padding-left 60px
				padding-right 60px

			+below($breakpoint-lg - 1px)
				padding-left 15px
				padding-right 15px

	&--calc
		padding 0
		margin-top -170px

		& > .container-fluid
			padding-left 15px
			padding-right 15px

			+below(1540px)
				padding-left 60px
				padding-right 60px

			+below($breakpoint-lg - 1px)
				padding-left 15px
				padding-right 15px

	&--contact
		padding 20px 0 1px
		background-color #1f3d6c
		color #fff

		p
			font-family $base-font-family
			font-size 18px
			font-weight normal
			line-height 1.222
			color inherit
			margin-bottom 22px

		.row
			margin-left -10px
			margin-right -10px

			.col-xs-6
			.col-xs-6
				padding-left 10px
				padding-right 10px

	&-input
		text-align center
		font-size 32px
		line-height 40px
		padding 20px
		height 80px
		text-transform uppercase
		font-family $base-font-family-medium
		position relative
		z-index 1

		+tablet()
			font-size 28px

		+mobile()
			font-size 28px

		.page__block--tracking &
			margin-top -80px

		.page__block--calc &
			margin-top -170px

	&-input-close
		width 80px
		height 80px
		line-height 80px
		text-align center
		position absolute
		right 0
		top 0
		display none
		cursor pointer
		z-index 2
	
		.page__block-input.has-close ~ &
			display block

		.icon:before
			position absolute
			left 50%
			top 50%
			transform translate(-50%, -50%)
			sprite($icon_close_dark_blue_21_21)

	.navigation__container
		margin-top -20px
		margin-bottom 10px

.page__map-tooltip
	position absolute
	left 50%
	top 50%

.page__block-group
	position relative

	.cabinet-link
		margin-top 0
		margin-bottom 0

.page-offcanvas
	position fixed


// ie 11

@media all and (-ms-high-contrast none)
	*::-ms-backdrop, div.page
		display block
		min-height 100%
		height auto
		position relative

	*::-ms-backdrop, .page__content
		display block
		padding-bottom 335px

	*::-ms-backdrop, .page__footer
		position absolute
		left 0
		bottom 0
		right 0
		height 335px
		overflow hidden

.page__error-container
	background-position 50% 50%
	background-size cover
	background-repeat no-repeat
	background-image url('../images/error-bg.jpg')
	text-align center
	padding-top 100px
	
	&
	& > .container-fluid
		min-height 900px
		height 100vh

.page__error-img
	display block
	max-width 100%
	height auto
	margin-left auto
	margin-right auto
	position relative
	
	&--404
		left 40px

	&--400
		left 75px

.page__error-text
	text-align center
	font-family $base-font-family-bold
	font-weight normal
	font-size 36px
	color #1d3b67
	dispay block
	margin -50px auto
	max-width 600px

.page__error-hint
	text-align center
	font-family $base-font-family-regulat
	font-weight normal
	font-size 20px
	color #1d3b67
	dispay block
	margin 200px auto 0

.page__body
	padding-top 114px