.card
	background-color #fff
	color #808285
	border 1px solid #acacac
	padding 20px 0

.card__turn
	display block
	width 18px
	height 18px
	text-align center
	line-height 18px
	float right
	cursor pointer
	margin-right 40px
	margin-bottom 10px

	&:before
		content ''
		display inline-block
		width 18px
		height 3px
		background-color #8b8b8b

.card__primary-content
	order 0
	flex-grow 2
	flex-shrink 1
	flex-basis auto
	text-decoration none
	box-sizing border-box
	display flex
	align-items center
	display block

.card__secondary-content
	display flex
	flex-direction column
	flex-wrap nowrap
	align-items flex-end
	margin-left 20px

.card__section
	display flex
	flex-direction row
	flex-wrap nowrap
	padding-left 20px
	padding-right 20px

	+below($breakpoint-lg - 1px)
		padding-left 40px
		padding-right 40px

	&-row
		display flex
		flex-direction row
		flex-wrap nowrap
		width 100%

		+below($breakpoint-lg - 1px)
			flex-direction column
			flex-wrap wrap

	.card__section-row &:first-child
		padding-left 40px

	.card__section-row &:last-child
		padding-right 40px

	.card--order &--left
		width calc(50% - 125px)

		+below($breakpoint-lg - 1px)
			width 100%
			margin-top 10px
			margin-bottom 10px

	.card--order &--center
		padding-right 40px
		width 250px
		text-align center

		+below($breakpoint-lg - 1px)
			width 100%
			margin-top 10px
			margin-bottom 10px

	.card--order &--right
		width calc(50% - 125px)

		+below($breakpoint-lg - 1px)
			width 100%
			margin-top 10px
			margin-bottom 10px

.card__secondary-info
	font-family $base-font-family-light
	font-weight normal
	font-size 16px
	line-height 1.2
	color #acacac
	padding-top 7px
	margin-bottom 7px

.card__secondary-text
	font-family $base-font-family-light
	font-weight normal
	font-size 21px
	line-height 1.2
	color inherit
	display block

	a&
		color inherit
		text-decoration none

.card__item
	display block
	margin-bottom 10px

	&:last-child
		margin-bottom 0

.card__item-title
	font-family $base-font-family-light
	font-weight normal
	font-size 24px
	line-height 1.2
	text-transform uppercase
	letter-spacing .1ex
	color #404041
	display block
	margin-bottom 5px

	a&
		color #404041
		text-decoration none

.card__item-text
	font-family $base-font-family-light
	font-weight normal
	font-size 21px
	line-height 1.2
	color inherit

	a&
		color inherit
		text-decoration none

.card__status
	font-family $base-font-family-light
	font-weight normal
	font-size 18px
	line-height 1.611
	text-transform uppercase
	letter-spacing .1ex
	color #404041
	display block
	white-space nowrap
	margin-bottom 5px
	max-width 202px
	margin-left auto
	margin-right auto

	.card--order &
		background-position 100% 50%
		background-repeat no-repeat
		background-image url('data:image/png;base64,')

		span
			display inline-block
			vertical-align middle
			background-color #fff
			padding-left 20px
			padding-right 20px

.card__number
	font-family $base-font-family-medium
	font-weight normal
	font-size 24px
	color #404041
	display block
	white-space nowrap
	margin 3px 0

.card__price
	font-family $base-font-family-light
	font-weight normal
	font-size 32px
	color #404041
	display block
	white-space nowrap
	margin 3px 0

.card__icon--marker
	&:before
		border solid transparent
		content ''
		height 0
		width 0
		border-color transparent
		border-left-color #ffd64a
		border-width 10px

	.card__item &
		width 20px
		margin-left -20px

.card--order-error
	position relative
	padding-top 30px
	padding-bottom 30px
	padding-left 18%
	padding-right 18%
	
	+below($breakpoint-lg - 1px)
		padding-left 95px
		padding-right 20px
	
	.card__inner
		position relative

	.icon
		position absolute
		right 100%
		top 0
		margin-right 25px

	.icon:before
		sprite($icon_attention_accent_50_45)

	h3
		font-family $base-font-family
		font-weight normal
		font-size 21px
		line-height normal
		color #404040
	
	p
		font-family $base-font-family-light
		font-weight normal
		font-size 18px
		line-height 20px
		color #8b8b8b
	

	h3
	p
		margin-top 0
		margin-bottom 20px
		
		&:last-child
			margin-bottom 0