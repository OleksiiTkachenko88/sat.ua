body
	font-family $font-family-base
	font-size $font-size-base
	font-weight normal
	line-height $line-height-base

h1, h2, h3, h4, h5, h6
	margin-top 0
	margin-bottom 11px

h1 small, h2 small, h3 small, h4 small, h5 small, h6 small
	font-size 0.6em

h1
	typo-display-4()

h2
	typo-display-3()

h3
	typo-display-2()

h4
	typo-display-1()

h5
	typo-headline()

h6
	typo-title()

p
	typo-body()
	margin-bottom 22px

a
	color $link-color
	font-weight normal

mark
	background-color #fff

dt
	font-weight 700

address
	typo-caption()
	font-style normal

ul, ol
	typo-body()
	margin-top 11px
	margin-bottom 22px

li
	margin-top 11px
	margin-bottom 11px

.typography--display-4
	typo-display-4()

.typography--display-3
	typo-display-3()

.typography--display-2
	typo-display-2()

.typography--display-1
	typo-display-1()

.typography--headline
	typo-headline()

.typography--title
	typo-title()

.typography--subhead
	typo-subhead()

.typography--caption
	typo-caption()

.typography--body
	typo-body()

.typography--body-small
	typo-body-small()

.typography--body-small-2
	typo-body-small-2()

.typography--text-left
	text-align left

.typography--text-right
	text-align right

.typography--text-center
	text-align center

.typography--text-justify
	text-align justify

.typography--text-nowrap
	white-space nowrap

.typography--text-lowercase
	text-transform lowercase

.typography--text-uppercase
	text-transform uppercase

.typography--text-capitalize
	text-transform capitalize

.typography--font-thin
	font-weight 200 !important

.typography--font-light
	font-weight 300 !important

.typography--font-regular
	font-weight 400 !important

.typography--font-medium
	font-weight 500 !important

.typography--font-bold
	font-weight 700 !important

.typography--font-black
	font-weight 900 !important

.typography--alert
	font-family 'Roboto Condensed', Arial, sans-serif !important
	font-weight normal
	font-size 36px
	line-height 55px
	text-transform uppercase
	color $brand-primary
