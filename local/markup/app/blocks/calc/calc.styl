.calc-group
	position relative
	border 1px solid #a0a0a0

	.calc-group .col > &
		margin-top -1px
		margin-left -1px
		margin-right -1px
		margin-bottom -1px

	&--transparent
		border none

.calc-group + .calc-group:not(.calc-group--transparent)
	margin-top -1px

.calc-group__title
.calc-group__content
	padding 25px 35px
	border-top 1px solid #a0a0a0
	border-bottom 1px solid #a0a0a0

	+below(1540px)
		padding-left 25px
		padding-right 25px

	+below($breakpoint-lg - 1px)
		padding-left 25px
		padding-right 25px

	&:first-child
		border-top none

	&:last-child
		border-bottom none

.calc-group__content
	padding-top 50px
	padding-bottom 50px

	+below($breakpoint-lg - 1px)
		padding-top 40px
		padding-bottom 40px

.calc-group__title + .calc-group__content
.calc-group__content + .calc-group__title
	margin-top -1px

.calc-group__title
	font-family $base-font-family-medium
	font-weight normal
	font-size 25px
	line-height normal
	text-transform uppercase
	color inherit
	position relative
	z-index 1
	margin 0

	a
		color inherit

.calc-group__row
	margin-left 0 !important
	margin-right 0 !important

	& > .col
		padding-left 0
		padding-right 0

	& > .col.first
		.calc-group__toggle + & .navbar
			padding-right 45px

			+below($breakpoint-lg - 1px)
				padding-right 0

	& > .col.second
		.calc-group__toggle + & .navbar
			padding-left 45px

			+below($breakpoint-lg - 1px)
				padding-left 0

.calc-group__toggle
	display inline-block
	width 82px
	height 41px
	border 1px solid #404040
	text-align center
	line-height 39px
	position absolute
	left 50%
	margin-left -41px
	margin-top 22px
	cursor pointer
	z-index 2

	+below($breakpoint-lg - 1px)
		display none

	&:before
		display inline-block
		vertical-align middle
		content ''
		sprite($icon_arrow_left_right_grey)

.calc__footer
	display block
	margin-top 40px
	margin-bottom 40px

	+below($breakpoint-lg - 1px)
		margin-top 30px
		margin-bottom 30px

.calc__container .uk-form-width-small
.calc__container .uk-form-width-mini
	padding-left 0
	padding-right 0
	text-align center
