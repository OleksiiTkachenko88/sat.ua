.cube__container
	width 302px
	height 302px
	position relative
	perspective 300px

	&:before
		content ''
		position absolute
		left -26px
		bottom -23px
		width 328px
		height 329px
		background-size cover
		background-repeat no-repeat
		background-image url('data:image/png;base64,')
		overflow hidden
		z-index -1

.cube
.cube figure
	transition transform .3s

.cube
	width 100%
	height 100%
	position absolute
	transform-style preserve-3d
	left 30px
	bottom -30px

	figure
		margin 0
		width 200px
		height 200px
		display block
		position absolute
		left 20px
		top 20px
		border 1px solid #e9e9e9

		&.front
			transform rotateY(   0deg ) translateZ( 100px )
			background alpha(#ffd64a, 0.63)
			display none

		&.back
			transform rotateX( 180deg ) translateZ( 100px )
			background alpha(#ffd64a, 0.63)

		&.right
			transform rotateY(  90deg ) translateZ( 100px )
			background alpha(#ffd64a, 0.51)

		&.left
			transform rotateY( -90deg ) translateZ( 100px )
			background alpha(#ffd64a, 0.51)

		&.top
			transform rotateX(  90deg ) translateZ( 100px )
			background alpha(#ffd64a, 0.63)

		&.bottom
			transform rotateX( -90deg ) translateZ( 100px )
			background alpha(#ffd64a, 0.63)

	&.show-front
		transform translateZ( -100px )

	&.show-back
		transform translateZ( -100px ) rotateX( -180deg )
	&.show-right

		transform translateZ( -100px ) rotateY(  -90deg )
	&.show-left

		transform translateZ( -100px ) rotateY(   90deg )

	&.show-top
		transform translateZ( -100px ) rotateX(  -90deg )

	&.show-bottom
		transform translateZ( -100px ) rotateX(   90deg )

.cube__container.step2
	.cube
		.front
			transform rotateY(   0deg )

		.back
			transform rotateX( 180deg )

		.right
			transform rotateY(  90deg )

		.left
			transform rotateY( -90deg )

		.top
			transform rotateX(  90deg )

		.bottom
			transform rotateX( -90deg )

.cube__container.step3 .front
.cube__container.step4 .front
	transform rotateY(   0deg ) translateZ( 100px )

.cube__container.step3 .front
.cube__container.step4 .front
	transform rotateX( 180deg ) translateZ( 100px )

.cube__container.step3 .front
.cube__container.step4 .front
	transform rotateY(  90deg ) translateZ( 100px )

.cube__container.step3 .front
.cube__container.step4 .front
	transform rotateY( -90deg ) translateZ( 100px )

.cube__container.step3 .front
.cube__container.step4 .front
	transform rotateX(  90deg ) translateZ( 100px )

.cube__container.step3 .front
.cube__container.step4 .front
	transform rotateX( -90deg ) translateZ( 100px )

.cube__container.step4 .front
	transform translateZ( -100px )

// ie 11
@media all and (-ms-high-contrast none)
	*::-ms-backdrop, .cube
		left 0
		bottom 0
		background #ffd64a

	*::-ms-backdrop, .cube figure.back
	*::-ms-backdrop, .cube figure.right
	*::-ms-backdrop, .cube figure.left
	*::-ms-backdrop, .cube figure.top
	*::-ms-backdrop, .cube figure.bottom
	*::-ms-backdrop, .cube figure.font
		display none
